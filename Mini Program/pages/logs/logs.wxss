.container {
  padding: 16rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.filter-tag {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #fff;
  color: #666;
}

.filter-tag.active {
  background: #07c160;
  color: #fff;
}

.clear-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #fa5151;
  padding: 8rpx 16rpx;
}

.log-list { max-height: calc(100vh - 120rpx); }

.log-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.log-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.log-time { color: #999; font-size: 24rpx; }

.log-type {
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #fff;
}
.log-type.info { background: #07c160; }
.log-type.error { background: #fa5151; }
.log-type.warn { background: #ff976a; }

.log-content {
  color: #333;
  font-size: 26rpx;
  word-break: break-all;
}

.log-empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 28rpx;
}
